  "keyFeatures": [
    "Complete CHIP-8 instruction set with 35+ opcodes",
    "Multi-platform support (CLI with ratatui, WebAssembly)",
    "Configurable clock speed and debug mode",
    "Zero external dependencies for core emulation",
    "Full memory management with 4KB RAM and 16-level stack",
    "Graphics rendering with 64x32 monochrome display",
    "16-key hexadecimal keypad input system",
    "Delay and sound timer implementation"
  ],
  "publicApiSurface": [
    "Chip8::new() -> Self",
    "Chip8::load_rom(path: PathBuf) -> Result<(), std::io::Error>",
    "Chip8::load_rom_bytes(rom: &[u8])",
    "Chip8::reset_and_load_bytes(rom: &[u8]) -> Result<(), Chip8Error>",
    "Chip8::Cycle()",
    "Chip8::play(speed: u64)",
    "Chip8::debug()",
    "Chip8::reset_hard()",
    "Chip8::key_down(k: u8)",
    "Chip8::key_up(k: u8)",
    "Chip8::is_key_down(k: u8) -> bool",
    "Chip8::export_video() -> &[u32; 64 * 32]",
    "Chip8::last_opcode() -> u16",
    "init(canvas_id: &str) -> Result<(), JsValue>",
    "step(n: u32)",
    "set_running(run: bool)",
    "set_delay_ms(ms: u32)",
    "load_rom(bytes: &[u8]) -> Result<(), JsValue>",
